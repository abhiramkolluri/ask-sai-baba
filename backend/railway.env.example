# Railway Environment Variables Template
# Copy this file and configure the values in your Railway project

# MongoDB Connection (Railway will provide this)
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here

# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=production
FLASK_DEBUG=0
FLASK_RUN_PORT=8000
FLASK_RUN_HOST=0.0.0.0

# Railway-specific variables
RAILWAY_STATIC_URL=your_railway_app_url_here
RAILWAY_ENVIRONMENT=production

# Optional: Logging
LOG_LEVEL=INFO
LOG_FILE=embedding_generation.log

# Optional: LangSmith (if using)
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=ask-sai-baba 